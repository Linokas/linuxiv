---
import { t, type Lang } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<div style="background-color: rgba(200,169,110,0.1); border: 1px solid rgba(200,169,110,0.4); border-radius: 10px; padding: 1rem 1.5rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
  <span style="font-size: 1.25rem;">🌐</span>
  <div>
    <p style="color: #c8a96e; font-weight: 700; font-size: 0.85rem; margin: 0 0 0.2rem;">{t(lang, 'wip.title')}</p>
    <p style="color: #8a8fa8; font-size: 0.85rem; margin: 0;">{t(lang, 'wip.body')}</p>
  </div>
</div>
