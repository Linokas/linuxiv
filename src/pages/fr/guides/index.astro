---
import GuidesLayout from '../../../layouts/GuidesLayout.astro';
import { t } from '../../../i18n/translations';
const lang = 'fr';
---
<GuidesLayout title={t(lang, 'guides.all_heading')} lang={lang}>
  <h1 style="font-size: 2rem; font-weight: 800; color: #e8e0d0; margin-bottom: 0.5rem;">{t(lang, 'guides.all_heading')}</h1>
  <p style="color: #8a8fa8; margin-bottom: 3rem;">{t(lang, 'guides.all_subheading')}</p>
  <div style="background-color: #1a1e2a; border: 1px solid #2a2f3e; border-radius: 12px; padding: 2rem; color: #8a8fa8; font-size: 0.95rem; line-height: 1.7;">
    Sélectionnez un guide dans la barre latérale.
  </div>
</GuidesLayout>
