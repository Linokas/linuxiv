---
import Layout from '../layouts/Layout.astro';

const guides = [
  {
    slug: 'penumbra',
    title: 'Penumbra',
    description: 'Mods zur Laufzeit laden ohne den Client zu patchen – der empfohlene Weg für Linux.',
    tags: ['Mods', 'Empfohlen'],
    difficulty: 'Einfach',
  },
  {
    slug: 'dalamud',
    title: 'Dalamud & XIVLauncher',
    description: 'XIVLauncher mit Dalamud-Plugin-Support auf Linux einrichten.',
    tags: ['Plugins', 'Launcher'],
    difficulty: 'Einfach',
  },
  {
    slug: 'textools',
    title: 'TexTools',
    description: 'TexTools unter Wine/Proton betreiben für direkte Datei-Modifikationen.',
    tags: ['Texturen', 'Wine'],
    difficulty: 'Mittel',
  },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section style="max-width: 1100px; margin: 0 auto; padding: 5rem 1.5rem 4rem;">
    <div style="max-width: 700px;">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: rgba(200,169,110,0.1); border: 1px solid rgba(200,169,110,0.3); border-radius: 9999px; padding: 0.35rem 1rem; margin-bottom: 1.5rem;">
        <span style="color: #c8a96e; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">Final Fantasy XIV auf Linux</span>
      </div>
      <h1 style="font-size: 3rem; font-weight: 800; line-height: 1.15; margin-bottom: 1.25rem; color: #e8e0d0;">
        Mods installieren<br/>
        <span style="background: linear-gradient(135deg, #c8a96e, #e0c68a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">unter Linux</span>
      </h1>
      <p style="font-size: 1.15rem; color: #8a8fa8; line-height: 1.7; margin-bottom: 2rem;">
        Schritt-für-Schritt Guides zum Einrichten von FF14 Mods auf Linux —
        von Penumbra über Dalamud bis TexTools.
      </p>
      <a href="/guides" style="display: inline-flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, #c8a96e, #e0c68a); color: #0d0f14; font-weight: 700; padding: 0.75rem 1.75rem; border-radius: 8px; text-decoration: none; font-size: 0.95rem;">
        Alle Guides ansehen →
      </a>
    </div>
  </section>

  <!-- Guides -->
  <section style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem 5rem;">
    <h2 style="font-size: 1.4rem; font-weight: 700; color: #e8e0d0; margin-bottom: 0.5rem;">Guides</h2>
    <p style="color: #8a8fa8; margin-bottom: 2rem; font-size: 0.95rem;">Wähle ein Tool, mit dem du starten möchtest.</p>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem;">
      {guides.map((guide) => (
        <a
          href={`/guides/${guide.slug}`}
          style="display: block; background-color: #1a1e2a; border: 1px solid #2a2f3e; border-radius: 12px; padding: 1.5rem; text-decoration: none; transition: border-color 0.2s;"
          onmouseover="this.style.borderColor='#c8a96e'"
          onmouseout="this.style.borderColor='#2a2f3e'"
        >
          <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem;">
            <h3 style="font-size: 1.1rem; font-weight: 700; color: #e8e0d0;">{guide.title}</h3>
            <span style={`font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 9999px; font-weight: 600; ${guide.difficulty === 'Einfach' ? 'background-color: rgba(74,217,130,0.15); color: #4ad982;' : 'background-color: rgba(200,169,110,0.15); color: #c8a96e;'}`}>
              {guide.difficulty}
            </span>
          </div>
          <p style="color: #8a8fa8; font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem;">{guide.description}</p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            {guide.tags.map((tag) => (
              <span style="font-size: 0.75rem; color: #8a8fa8; background-color: #13161e; border: 1px solid #2a2f3e; padding: 0.15rem 0.6rem; border-radius: 4px;">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Info banner -->
  <section style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem 5rem;">
    <div style="background-color: rgba(74,144,217,0.08); border: 1px solid rgba(74,144,217,0.3); border-radius: 12px; padding: 1.5rem 2rem;">
      <p style="color: #8a8fa8; font-size: 0.9rem; line-height: 1.7; margin: 0;">
        <strong style="color: #4a90d9;">Hinweis:</strong> Das Modden von FF14 geschieht auf eigenes Risiko und kann gegen die Nutzungsbedingungen verstoßen.
        Diese Guides dienen ausschließlich zu Bildungszwecken. Bitte informiere dich über die aktuellen Regeln von Square Enix.
      </p>
    </div>
  </section>
</Layout>
