---
import GuidesLayout from '../../../layouts/GuidesLayout.astro';
import { t } from '../../../i18n/translations';
const lang = 'ja';
---
<GuidesLayout title="CachyOS ガイド" lang={lang}>
  <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; font-size: 0.85rem; color: #8a8fa8;">
    <a href={`/${lang}/`} style="color: #8a8fa8; text-decoration: none;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">ホーム</a>
    <span>›</span>
    <a href={`/${lang}/guides`} style="color: #8a8fa8; text-decoration: none;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">{t(lang, 'breadcrumb.guides')}</a>
    <span>›</span>
    <span style="color: #c8a96e;">CachyOS</span>
  </div>
  <h1 style="font-size: 2.25rem; font-weight: 800; color: #e8e0d0; margin-bottom: 0.75rem;">CachyOS</h1>
  <p style="color: #8a8fa8; font-size: 1rem; line-height: 1.7;">ガイドは近日公開予定です。</p>
</GuidesLayout>
