---
import Layout from '../../../layouts/Layout.astro';
import DalamudContent from '../../../components/guides/DalamudContent.astro';
import { t } from '../../../i18n/translations';
const lang = 'en';
---
<Layout title="Dalamud & XIVLauncher Guide" lang={lang}>
  <div style="max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; font-size: 0.85rem; color: #8a8fa8;">
      <a href={`/${lang}/`} style="color: #8a8fa8; text-decoration: none;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">Home</a>
      <span>›</span>
      <a href={`/${lang}/guides`} style="color: #8a8fa8; text-decoration: none;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">{t(lang, 'breadcrumb.guides')}</a>
      <span>›</span>
      <span style="color: #c8a96e;">Dalamud & XIVLauncher</span>
    </div>
    <div style="margin-bottom: 2.5rem;">
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
        <span style="font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 9999px; background-color: rgba(74,217,130,0.15); color: #4ad982; font-weight: 600;">{t(lang, 'difficulty.easy')}</span>
      </div>
      <h1 style="font-size: 2.25rem; font-weight: 800; color: #e8e0d0; margin-bottom: 0.75rem;">Dalamud & XIVLauncher</h1>
      <p style="color: #8a8fa8; font-size: 1rem; line-height: 1.7;">XIVLauncher is an unofficial launcher for FF14 that integrates Dalamud — a plugin platform that tools like Penumbra are built on. XIVLauncher has native Linux support.</p>
    </div>
    <DalamudContent />
    <div style="display: flex; justify-content: space-between; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #2a2f3e;">
      <a href={`/${lang}/guides`} style="color: #8a8fa8; text-decoration: none; font-size: 0.9rem;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">{t(lang, 'guide.back')}</a>
      <a href={`/${lang}/guides/penumbra`} style="color: #c8a96e; text-decoration: none; font-size: 0.9rem;">Penumbra →</a>
    </div>
  </div>
</Layout>
