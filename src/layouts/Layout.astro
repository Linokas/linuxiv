---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Guides zum Installieren von FF14 Mods auf Linux' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | linuxiv.com</title>
  </head>
  <body style="background-color: #0d0f14; color: #e8e0d0;">
    <header style="background-color: #13161e; border-bottom: 1px solid #2a2f3e; position: sticky; top: 0; z-index: 50;">
      <div style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px;">
        <a href="/" style="display: flex; align-items: center; gap: 0.75rem; text-decoration: none;">
          <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #c8a96e, #e0c68a); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1rem; color: #0d0f14;">
            XIV
          </div>
          <span style="font-weight: 700; font-size: 1.1rem; color: #e8e0d0;">linuxiv<span style="color: #c8a96e;">.com</span></span>
        </a>
        <nav style="display: flex; gap: 2rem; align-items: center;">
          <a href="/" style="color: #8a8fa8; text-decoration: none; font-size: 0.9rem; transition: color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">Home</a>
          <a href="/guides" style="color: #8a8fa8; text-decoration: none; font-size: 0.9rem;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='#8a8fa8'">Guides</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="border-top: 1px solid #2a2f3e; margin-top: 5rem; padding: 2rem 1.5rem; text-align: center;">
      <p style="color: #8a8fa8; font-size: 0.85rem;">
        linuxiv.com — FF14 Modding auf Linux &nbsp;·&nbsp; Kein offizieller Bezug zu Square Enix
      </p>
    </footer>
  </body>
</html>
